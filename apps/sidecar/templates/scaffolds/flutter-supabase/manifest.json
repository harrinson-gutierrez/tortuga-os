{
  "stack": "flutter-supabase",
  "displayName": "Flutter + Supabase",
  "description": "App Flutter (Android + Web) con Supabase Auth + Postgres + RLS, Riverpod + go_router, Material 3.",
  "steps": [
    {
      "id": "flutter-create",
      "label": "Crear esqueleto Flutter",
      "type": "bash",
      "command": "flutter",
      "args": [
        "create",
        "--org",
        "com.tortugaos",
        "--project-name",
        "{{projectSlug}}",
        "--platforms=android,web",
        "05-build/app"
      ],
      "cwd": "."
    },
    {
      "id": "pub-add-deps",
      "label": "Instalar dependencias (Riverpod, Supabase, go_router, fl_chart, intl)",
      "type": "bash",
      "command": "flutter",
      "args": [
        "pub",
        "add",
        "flutter_riverpod",
        "supabase_flutter",
        "go_router",
        "fl_chart",
        "intl",
        "flutter_dotenv"
      ],
      "cwd": "05-build/app"
    },
    {
      "id": "pub-add-dev-mocktail",
      "label": "Instalar mocktail (testing)",
      "type": "bash",
      "command": "flutter",
      "args": ["pub", "add", "--dev", "mocktail"],
      "cwd": "05-build/app"
    },
    {
      "id": "pub-add-dev-integration-test",
      "label": "Instalar integration_test (Flutter SDK)",
      "type": "bash",
      "command": "flutter",
      "args": ["pub", "add", "--dev", "--sdk=flutter", "integration_test"],
      "cwd": "05-build/app"
    },
    {
      "id": "pub-add-dev-alchemist",
      "label": "Instalar alchemist (golden tests sin platform-quirks)",
      "type": "bash",
      "command": "flutter",
      "args": ["pub", "add", "--dev", "alchemist"],
      "cwd": "05-build/app"
    }
  ],
  "files": [
    {
      "to": "05-build/app/lib/main.dart",
      "fromTemplate": "files/main.dart.tpl"
    },
    {
      "to": "05-build/app/lib/core/theme.dart",
      "fromTemplate": "files/theme.dart.tpl"
    },
    {
      "to": "05-build/app/lib/core/router.dart",
      "fromTemplate": "files/router.dart.tpl"
    },
    {
      "to": "05-build/app/lib/core/supabase.dart",
      "fromTemplate": "files/supabase.dart.tpl"
    },
    {
      "to": "05-build/app/.env.example",
      "fromTemplate": "files/env.example.tpl"
    },
    {
      "to": "ARCHITECTURE.md",
      "fromTemplate": "files/ARCHITECTURE.md.tpl"
    },
    {
      "to": "05-build/app/test/flutter_test_config.dart",
      "fromTemplate": "files/flutter_test_config.dart.tpl"
    },
    {
      "to": "05-build/app/test/smoke_test.dart",
      "fromTemplate": "files/smoke_test.dart.tpl"
    },
    {
      "to": "05-build/app/test/smoke_golden_test.dart",
      "fromTemplate": "files/smoke_golden_test.dart.tpl"
    },
    {
      "to": "05-build/app/test/widget_test.dart",
      "fromTemplate": "files/widget_test.dart.tpl"
    },
    {
      "to": "05-build/app/integration_test/app_boot_test.dart",
      "fromTemplate": "files/app_boot_test.dart.tpl"
    },
    {
      "to": "05-build/app/integration_test/app_golden_test.dart",
      "fromTemplate": "files/app_golden_test.dart.tpl"
    },
    {
      "to": "05-build/app/test/README.md",
      "fromTemplate": "files/test_README.md.tpl"
    }
  ],
  "verify": [
    {
      "id": "analyze",
      "label": "Verificar tipos",
      "command": "flutter",
      "args": ["analyze", "--no-pub", "--no-fatal-infos"],
      "cwd": "05-build/app"
    },
    {
      "id": "generate-goldens",
      "label": "Generar baselines de goldens (seed)",
      "command": "flutter",
      "args": ["test", "--update-goldens", "test/smoke_golden_test.dart"],
      "cwd": "05-build/app"
    },
    {
      "id": "test",
      "label": "Correr unit + widget + golden tests (host)",
      "command": "flutter",
      "args": ["test", "--reporter=expanded"],
      "cwd": "05-build/app"
    }
  ]
}
