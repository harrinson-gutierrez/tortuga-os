{
  "name": "@tortuga/sidecar",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./src/main.ts",
  "scripts": {
    "dev": "cross-env PORT=31415 tsx watch --env-file=.env src/main.ts",
    "dev:mcp": "tsx src/mcp/server.ts",
    "start": "node --import tsx/esm src/main.ts",
    "build": "node ./build.mjs",
    "build:dev": "node ./build.mjs --dev",
    "build:run": "node dist-bundle/sidecar.cjs",
    "build:mcp:run": "node dist-bundle/mcp-server.cjs",
    "seed": "tsx src/seed/run.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.100.0",
    "@hono/node-server": "^1.13.7",
    "@hono/node-ws": "^1.3.1",
    "@hono/zod-validator": "^0.8.0",
    "@modelcontextprotocol/sdk": "^1.0.4",
    "@tortuga-os/agent-runner": "workspace:*",
    "@tortuga-os/api-server": "workspace:*",
    "@tortuga-os/contracts": "workspace:*",
    "@tortuga-os/mcp-server": "workspace:*",
    "@tortuga-os/core": "workspace:*",
    "@tortuga-os/fs-workspace": "workspace:*",
    "@tortuga-os/storage-sqlite": "workspace:*",
    "@yume-chan/adb": "2.6.0",
    "@yume-chan/adb-scrcpy": "2.3.2",
    "@yume-chan/adb-server-node-tcp": "2.5.2",
    "@yume-chan/scrcpy": "2.3.0",
    "@yume-chan/stream-extra": "2.5.3",
    "better-sqlite3": "^11.5.0",
    "chokidar": "^4.0.1",
    "drizzle-orm": "^0.45.2",
    "gray-matter": "^4.0.3",
    "hono": "^4.12.23",
    "pino": "^9.5.0",
    "pino-pretty": "^11.3.0",
    "uuid": "^11.0.3",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@tortuga-os/tsconfig": "workspace:*",
    "@types/node": "^22.10.0",
    "cross-env": "^7.0.3",
    "esbuild": "^0.24.0",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3"
  }
}
