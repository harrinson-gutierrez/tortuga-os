{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Default capabilities for the main window",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "core:window:default",
    "core:window:allow-request-user-attention",
    "core:webview:default",
    "core:event:default",
    "core:menu:default",
    "log:default",
    "dialog:allow-open"
  ]
}
